{
  "attributes": {
    "paccEnabled": {
      "type": "bool",
      "default": 0,
      "documentation": "Enable PACC endpoint for mail client autoconfiguration"
    },
    "paccAllowNativeClientRegistration": {
      "type": "bool",
      "default": 1,
      "documentation": "Allow dynamic registration for native clients even if globally disabled"
    },
    "paccStrictNativeClientOnly": {
      "type": "bool",
      "default": 1,
      "documentation": "Reject registration if not all redirect_uris are loopback (native client)"
    },
    "paccImapEnabled": {
      "type": "bool",
      "default": 0,
      "documentation": "Enable IMAP server in PACC configuration"
    },
    "paccImapHostname": {
      "type": "hostname",
      "documentation": "IMAP server hostname"
    },
    "paccImapPort": {
      "type": "int",
      "default": 993,
      "documentation": "IMAP server port"
    },
    "paccImapAuth": {
      "type": "text",
      "default": "OAuth2 sasl-SCRAM-SHA-256-PLUS",
      "documentation": "IMAP authentication methods (space-separated)"
    },
    "paccSmtpEnabled": {
      "type": "bool",
      "default": 0,
      "documentation": "Enable SMTP server in PACC configuration"
    },
    "paccSmtpHostname": {
      "type": "hostname",
      "documentation": "SMTP server hostname"
    },
    "paccSmtpPort": {
      "type": "int",
      "default": 465,
      "documentation": "SMTP server port"
    },
    "paccSmtpAuth": {
      "type": "text",
      "default": "OAuth2",
      "documentation": "SMTP authentication methods (space-separated)"
    },
    "paccJmapEnabled": {
      "type": "bool",
      "default": 0,
      "documentation": "Enable JMAP in PACC configuration"
    },
    "paccJmapUrl": {
      "type": "url",
      "documentation": "JMAP service URL"
    },
    "paccCalDavEnabled": {
      "type": "bool",
      "default": 0,
      "documentation": "Enable CalDAV in PACC configuration"
    },
    "paccCalDavUrl": {
      "type": "url",
      "documentation": "CalDAV service URL"
    },
    "paccCardDavEnabled": {
      "type": "bool",
      "default": 0,
      "documentation": "Enable CardDAV in PACC configuration"
    },
    "paccCardDavUrl": {
      "type": "url",
      "documentation": "CardDAV service URL"
    }
  },
  "tree": {
    "insert_into": "oidcServiceMetaData/oidcServiceDynamicRegistration",
    "insert_after": "oidcServiceDynamicRegistrationExtraClaims",
    "nodes": [
      {
        "title": "paccConfiguration",
        "help": "pacc.html",
        "nodes": [
          "paccEnabled",
          "paccAllowNativeClientRegistration",
          "paccStrictNativeClientOnly",
          {
            "title": "paccImapSettings",
            "help": "pacc.html#imap-settings",
            "form": "simpleInputContainer",
            "nodes": [
              "paccImapEnabled",
              "paccImapHostname",
              "paccImapPort",
              "paccImapAuth"
            ]
          },
          {
            "title": "paccSmtpSettings",
            "help": "pacc.html#smtp-settings",
            "form": "simpleInputContainer",
            "nodes": [
              "paccSmtpEnabled",
              "paccSmtpHostname",
              "paccSmtpPort",
              "paccSmtpAuth"
            ]
          },
          {
            "title": "paccOtherProtocols",

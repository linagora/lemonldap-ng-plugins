            "nodes": [
              "paccJmapEnabled",
              "paccJmapUrl",
              "paccCalDavEnabled",
              "paccCalDavUrl",
              "paccCardDavEnabled",
              "paccCardDavUrl"
            ]
          }
        ]
      }
    ]
  },

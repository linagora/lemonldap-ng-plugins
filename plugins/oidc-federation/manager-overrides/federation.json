      "default": "default-oidc-sig",
      "documentation": "Key ID used for signing federation entity statements"
    },
    "oidcFederationSigningAlg": {
      "type": "select",
      "select": [
        { "k": "RS256", "v": "RS256" },
        { "k": "RS384", "v": "RS384" },
        { "k": "RS512", "v": "RS512" },
        { "k": "ES256", "v": "ES256" },
        { "k": "ES384", "v": "ES384" },
        { "k": "ES512", "v": "ES512" }
      ],
      "default": "RS256",
      "documentation": "Algorithm for signing federation entity statements"
    },
    "oidcFederationTrustAnchors": {
      "type": "keyTextContainer",

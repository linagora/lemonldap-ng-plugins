{
  "attributes": {
    "oidcFederationEnabled": {
      "type": "bool",
      "default": 0,
      "documentation": "Enable OpenID Federation support"
    },
    "oidcFederationEntityId": {
      "type": "text",
      "documentation": "OpenID Federation entity identifier (defaults to issuer URL)"
    },
